@model IEnumerable<EticaretUygulamasi.Models.Urun>
@using System.Globalization

@{
    ViewData["Title"] = "Ürünler";
}

<div class="container mt-4">
    <form asp-controller="Urun" asp-action="Index" method="get">
        <div class="row mb-4 align-items-center">
            <div class="col-lg-3 col-md-12">
                <h2>Ürünler</h2>
            </div>
            <div class="col-lg-9 col-md-12 d-flex flex-wrap justify-content-end align-items-center">
                <div class="col-md-auto flex-grow-1 flex-shrink-1 me-3 mb-2 mb-lg-0">
                    <div class="input-group">
                        <input class="form-control" type="search" name="searchString" placeholder="Ürün ara..." value="@ViewBag.CurrentSearch">
                        <button class="btn btn-outline-primary" type="submit">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </div>
                <div class="col-md-auto flex-grow-1 flex-shrink-1 me-3 mb-2 mb-lg-0" style="max-width: 300px;">
                    <div class="input-group">
                        <input type="number" class="form-control" name="minPrice" placeholder="Min Fiyat" value="@ViewBag.CurrentMinPrice" min="0">
                        <span class="input-group-text">₺</span>
                        <input type="number" class="form-control" name="maxPrice" placeholder="Max Fiyat" value="@ViewBag.CurrentMaxPrice" min="0">
                        <span class="input-group-text">₺</span>
                        <button type="submit" class="btn btn-outline-primary">Filtrele</button>
                    </div>
                </div>
                <div class="col-md-auto flex-grow-0 flex-shrink-0 mb-2 mb-lg-0">
                    <div class="btn-group">
                        <a href="@Url.Action("Index", new { sortOrder = ViewBag.NameSortParm, searchString = ViewBag.CurrentSearch, kategoriId = ViewBag.CurrentKategori, minPrice = ViewBag.CurrentMinPrice, maxPrice = ViewBag.CurrentMaxPrice })" 
                           class="btn btn-outline-secondary @(ViewBag.CurrentSort == "name" || ViewBag.CurrentSort == "name_desc" ? "active" : "")">
                            <i class="fas fa-sort-alpha-down"></i> İsme Göre
                        </a>
                        <a href="@Url.Action("Index", new { sortOrder = ViewBag.PriceSortParm, searchString = ViewBag.CurrentSearch, kategoriId = ViewBag.CurrentKategori, minPrice = ViewBag.CurrentMinPrice, maxPrice = ViewBag.CurrentMaxPrice })" 
                           class="btn btn-outline-secondary @(ViewBag.CurrentSort == "price" || ViewBag.CurrentSort == "price_desc" ? "active" : "")">
                            <i class="fas fa-sort-numeric-down"></i> Fiyata Göre
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i>
            Aradığınız kriterlere uygun ürün bulunamadı.
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
            @foreach (var urun in Model)
            {
                <div class="col">
                    <div class="card">
                        <div class="position-relative">
                            @if (!string.IsNullOrEmpty(urun.ResimUrl))
                            {
                                <img src="@urun.ResimUrl" class="card-img-top img-fluid" alt="@urun.UrunAdi"
                                     style="width: 100%; height: 100%; object-fit: cover;">
                            }
                            else
                            {
                                <div class="bg-light d-flex align-items-center justify-content-center"
                                     style="width: 100%; height: 100%;">
                                    <i class="fas fa-image fa-3x text-muted"></i>
                                </div>
                            }
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-truncate">@urun.UrunAdi</h5>
                            <p class="card-text text-muted small mb-2">@urun.Kategori?.KategoriAdi</p>
                            <p class="product-description">@(urun.Aciklama?.Length > 100 ? urun.Aciklama.Substring(0, 100) + "..." : urun.Aciklama)</p>
                            <div class="d-flex justify-content-between align-items-center mt-auto">
                                <span class="h5 mb-0">@string.Format("{0:N2} ₺", urun.Fiyat)</span>
                                <form asp-controller="Sepet" asp-action="AddToCart" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="urunId" value="@urun.UrunId" />
                                    <input type="hidden" name="miktar" value="1" />
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fas fa-cart-plus"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-top-0">
                            <a asp-action="Details" asp-route-id="@urun.UrunId" class="btn btn-outline-secondary w-100">
                                <i class="fas fa-info-circle me-2"></i>Detaylar
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        // Kartların yüksekliğini eşitle
        function equalizeCardHeights() {
            var cards = document.querySelectorAll('.card');
            var maxHeight = 0;

            cards.forEach(function(card) {
                var height = card.offsetHeight;
                maxHeight = Math.max(maxHeight, height);
            });

            cards.forEach(function(card) {
                card.style.height = maxHeight + 'px';
            });
        }

        // Sayfa yüklendiğinde ve pencere boyutu değiştiğinde kartları eşitle
        window.addEventListener('load', equalizeCardHeights);
        window.addEventListener('resize', equalizeCardHeights);
    </script>
} 